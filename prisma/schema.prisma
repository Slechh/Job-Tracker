generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Job {
  id        Int      @id @default(autoincrement())
  company   String
  position  String
  status    String   @default("Saved")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}